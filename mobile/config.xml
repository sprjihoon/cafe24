<?xml version="1.0" encoding="utf-8"?>
<config>
    <title>ATELIER N Premium Skin (Mobile)</title>
    <version>1.0.0</version>
    <date>2026-06-29</date>
    <description>
        <![CDATA[
        <div style="padding: 20px; line-height: 1.8;">
            <h2 style="margin-bottom: 15px;">ATELIER N 모바일 스킨</h2>
            <p style="margin-bottom: 10px;">
                ATELIER N PC 스킨에 대응하는 모바일 전용 스킨입니다.
            </p>
            <h3 style="margin: 20px 0 10px;">주요 기능</h3>
            <ul style="padding-left: 20px;">
                <li>터치 최적화 슬라이더</li>
                <li>모바일 사이드바 드로어 메뉴</li>
                <li>Swiper 기반 상품/리뷰/배너 슬라이더</li>
                <li>모바일 전용 반응형 레이아웃</li>
            </ul>
            <p style="margin-top: 20px; color: #666;">
                문의: support@atelier-n.kr
            </p>
        </div>
        ]]>
    </description>

    <!-- 로고 설정 -->
    <display name="로고 설정">
        <image name="로고 이미지" var="logo_image" path="/web/upload/logo/" default="/web/upload/logo/logo.png">
            <![CDATA[
            상단 헤더에 표시될 로고 이미지를 업로드하세요. (권장 크기: 120x36px)
            ]]>
        </image>
        <text name="쇼핑몰 이름" var="mall_name" default="ATELIER N">
            <![CDATA[
            로고 이미지가 없을 경우 표시될 쇼핑몰 이름
            ]]>
        </text>
    </display>

    <!-- 마키 배너 -->
    <display name="마키 배너">
        <text name="마키 텍스트" var="marquee_text" default="50,000원 이상 무료배송 · 30일 무료반품 · 자연스럽게 스며드는 정돈된 여성복">
            <![CDATA[
            상단에 무한 반복되는 텍스트 (· 로 구분)
            ]]>
        </text>
    </display>

    <!-- 브랜드 색상 -->
    <display name="브랜드 색상">
        <color name="강조 색상" var="accent_color" default="#d4c4b0">
            <![CDATA[
            버튼, 링크 등에 적용되는 강조 색상
            ]]>
        </color>
        <color name="다크 색상" var="charcoal_color" default="#1d1d1f">
            <![CDATA[
            헤더, 텍스트에 적용되는 다크 색상
            ]]>
        </color>
    </display>
</config>
